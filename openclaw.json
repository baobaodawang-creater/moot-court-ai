{
  "gateway": {
    "port": 18789,
    "bind": "127.0.0.1",
    "auth": {
      "mode": "token"
    }
  },

  "models": {
    "providers": {
      "custom-api-deepseek-com": {
        "baseUrl": "https://api.deepseek.com/v1",
        "apiKey": "${DEEPSEEK_API_KEY}"
      },
      "custom-api-dashscope": {
        "baseUrl": "https://dashscope.aliyuncs.com/compatible-mode/v1",
        "apiKey": "${DASHSCOPE_API_KEY}"
      }
    }
  },

  "plugins": {
    "entries": {
      "memory-lancedb": {
        "enabled": true,
        "config": {
          "db": "~/.openclaw/memory/lancedb"
        }
      },
      "llm-task": {
        "enabled": true
      },
      "lobster": {
        "enabled": true
      }
    }
  },

  "tools": {
    "agentToAgent": {
      "enabled": false
    }
  },

  "session": {
    "scope": "per-sender"
  },

  "agents": {
    "defaults": {
      "model": "custom-api-deepseek-com/deepseek-chat"
    },
    "list": [
      {
        "id": "clerk",
        "name": "书记员",
        "model": "custom-api-deepseek-com/deepseek-chat",
        "agentDir": "~/.openclaw/agents/clerk/agent",
        "workspace": "~/moot-court-ai/agents/clerk/workspace",
        "tools": {
          "allow": ["lobster", "llm-task"]
        }
      },
      {
        "id": "plaintiff",
        "name": "原告律师",
        "model": "custom-api-deepseek-com/deepseek-reasoner",
        "agentDir": "~/.openclaw/agents/plaintiff/agent",
        "workspace": "~/moot-court-ai/agents/plaintiff/workspace",
        "tools": {
          "deny": ["lobster"]
        }
      },
      {
        "id": "defendant",
        "name": "被告律师",
        "model": "custom-api-dashscope/qwen-max",
        "agentDir": "~/.openclaw/agents/defendant/agent",
        "workspace": "~/moot-court-ai/agents/defendant/workspace",
        "tools": {
          "deny": ["lobster"]
        }
      },
      {
        "id": "judge",
        "name": "法官",
        "model": "custom-api-deepseek-com/deepseek-reasoner",
        "agentDir": "~/.openclaw/agents/judge/agent",
        "workspace": "~/moot-court-ai/agents/judge/workspace",
        "tools": {
          "allow": ["lobster", "llm-task", "memory-lancedb"]
        }
      }
    ]
  },

  "channels": {
    "webchat": {}
  }
}
