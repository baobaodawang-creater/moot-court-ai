# Moot Court AI - 环境变量配置
# 复制此文件为 .env 并填入你的 API Keys

# DeepSeek API Key (https://platform.deepseek.com)
# 用于: clerk (deepseek-chat), plaintiff (deepseek-reasoner), judge (deepseek-reasoner)
DEEPSEEK_API_KEY=sk-你的DeepSeek密钥

# 阿里云百炼 API Key (https://bailian.console.aliyun.com)
# 用于: defendant (qwen-max)
DASHSCOPE_API_KEY=sk-你的百炼密钥
